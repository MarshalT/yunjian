{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "云笺主窗口默认权限配置",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-ask",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$HOME/**" }
      ]
    }
  ]
}
